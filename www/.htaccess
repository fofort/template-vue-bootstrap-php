SetEnv APP_ENV "local" 
SetEnv APP_DB_SERVER="localhost"
SetEnv APP_DB_USERNAME="root"
SetEnv APP_DB_PASSWORD=""
SetEnv APP_DB_NAME="dbname"

# disable the display of folder contain
Options -Indexes 

# proper redirection for error message
# ErrorDocument 403 "Sorry, you do not have permission to access this file"
ErrorDocument 403 /403.html
ErrorDocument 404 /404.html


# rewritting rule for vue app
RewriteEngine On
RewriteBase /
RewriteRule ^index\.html$ - [L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /index.html [L]
